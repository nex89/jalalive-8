---
// NewHouseFlip Template - jalalive-2
// Style: Eeshape Inspired (Clean, Minimalist, Emerald)
// Link: cukurukuk.co (Partner Resmi)

const siteUrl = "https://www.newhouseflip.com";
const partnerUrl = "https://cukurukuk.co"; // URL Partner Resmi
const pageTitle = "JALALIVE - Live Football Streaming HD & Match Schedules";
const pageDesc = "Nonton siaran langsung sepak bola kualitas HD. Jadwal pertandingan terlengkap hari ini, partner resmi dari JALALIVE melalui cukurukuk.co.";

const matches = [
  { time: "02:00", date: "02 Mei", home: "Real Madrid", away: "Man City", league: "Champions League" },
  { time: "02:00", date: "02 Mei", home: "Bayern Munich", away: "Arsenal", league: "Champions League" },
  { time: "23:45", date: "03 Mei", home: "AS Roma", away: "AC Milan", league: "Europa League" },
  { time: "02:00", date: "03 Mei", home: "Liverpool", away: "Atalanta", league: "Europa League" },
  { time: "18:30", date: "04 Mei", home: "Arsenal", away: "Bournemouth", league: "Premier League" },
  { time: "21:00", date: "04 Mei", home: "Man City", away: "Wolves", league: "Premier League" },
  { time: "21:15", date: "04 Mei", home: "Real Madrid", away: "Cadiz", league: "La Liga" },
  { time: "23:30", date: "04 Mei", home: "Girona", away: "Barcelona", league: "La Liga" },
  { time: "01:45", date: "05 Mei", home: "Sassuolo", away: "Inter Milan", league: "Serie A" },
  { time: "20:00", date: "05 Mei", home: "Chelsea", away: "West Ham", league: "Premier League" },
  { time: "22:30", date: "05 Mei", home: "Liverpool", away: "Spurs", league: "Premier League" },
  { time: "02:00", date: "06 Mei", home: "Crystal Palace", away: "Man United", league: "Premier League" },
  { time: "02:00", date: "08 Mei", home: "PSG", away: "Dortmund", league: "Champions League" },
  { time: "02:00", date: "09 Mei", home: "Real Madrid", away: "Bayern", league: "Champions League" },
  { time: "02:00", date: "10 Mei", home: "Leverkusen", away: "Roma", league: "Europa League" }
];
---

<html lang="id">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" href="data:," /> <!-- Matikan Favicon secara total -->

    <style>
        :root {
            --emerald: #10b981;
            --dark-bg: #022c22;
            --card-bg: #0a0a0a;
        }
        body {
            background-color: #000;
            color: #fff;
            font-family: 'Inter', sans-serif;
            margin: 0;
            -webkit-user-select: none; user-select: none; /* Proteksi Anti-Copy */
        }
        .nav {
            padding: 30px 20px;
            max-width: 1100px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .logo { font-size: 1.4rem; font-weight: 800; letter-spacing: -1px; text-decoration: none; color: #fff; }
        .logo span { color: var(--emerald); }
        .partner-btn { color: var(--emerald); text-decoration: none; font-size: 0.7rem; font-weight: bold; border: 1px solid rgba(16, 185, 129, 0.3); padding: 5px 12px; border-radius: 20px; transition: 0.3s; }
        .partner-btn:hover { background: var(--emerald); color: #000; }
        
        .hero {
            text-align: center;
            padding: 60px 20px;
            background: linear-gradient(to bottom, var(--dark-bg), #000);
        }
        .hero h1 { font-size: 2.5rem; margin-bottom: 10px; }
        .hero p { color: var(--emerald); font-weight: 600; font-size: 0.8rem; letter-spacing: 2px; text-transform: uppercase; }

        .container { max-width: 800px; margin: 0 auto; padding: 20px; }

        .match-row {
            display: grid;
            grid-template-columns: 100px 1fr 100px;
            align-items: center;
            padding: 22px;
            border-bottom: 1px solid #111;
            transition: background 0.3s;
        }
        .match-row:hover { background: #050505; }
        .time { font-weight: 800; font-size: 1.1rem; color: #eee; }
        .teams { font-weight: 600; font-size: 1.05rem; }
        .teams small { display: block; color: #555; font-size: 0.75rem; margin-top: 5px; text-transform: uppercase; letter-spacing: 1px; }
        
        .btn-live {
            text-align: center;
            color: var(--emerald);
            text-decoration: none;
            font-weight: 800;
            font-size: 0.75rem;
            border: 1px solid var(--emerald);
            padding: 6px 12px;
            border-radius: 4px;
            transition: all 0.3s;
        }
        .btn-live:hover { background: var(--emerald); color: #000; }

        .article-section {
            margin-top: 80px;
            line-height: 1.9;
            color: #888;
            border-top: 1px solid #1a1a1a;
            padding: 50px 0 100px;
        }
        .article-section h2, .article-section h3 { color: #fff; margin-top: 40px; }
        .article-section p { margin-bottom: 20px; text-align: justify; }
        .article-section a { color: var(--emerald); text-decoration: underline; }
    </style>
</head>
<body oncontextmenu="return false;">

    <nav class="nav">
        <a href="/" class="logo">NEWHOUSE<span>FLIP</span></a>
        <a href={partnerUrl} target="_blank" class="partner-btn">GOTO CUKURUKUK.CO</a>
    </nav>

    <header class="hero">
        <p>Official Partner JALALIVE</p>
        <h1>Jadwal Bola Hari Ini</h1>
    </header>

    <main class="container">
        <div class="match-list">
            {matches.map((m) => (
                <div class="match-row">
                    <div class="time">{m.time}</div>
                    <div class="teams">
                        {m.home} vs {m.away}
                        <small>{m.league} • {m.date}</small>
                    </div>
                    <a href={partnerUrl} target="_blank" class="btn-live">NONTON</a>
                </div>
            ))}
        </div>

        <article class="article-section">
            <h2>Analisis Mendalam & Layanan Eksklusif JALALIVE</h2>
            <p>
                Dalam era digital yang berkembang pesat, **JALALIVE** muncul sebagai destinasi utama bagi para penggemar sepak bola yang mendambakan kualitas tanpa kompromi. Mengambil inspirasi dari filosofi desain minimalis **eeshape**, kami percaya bahwa antarmuka yang bersih adalah kunci untuk kenyamanan pengguna dalam mengakses informasi jadwal pertandingan yang padat. Fokus kami bukan hanya pada kuantitas, tetapi pada presisi data yang disajikan secara real-time melalui kolaborasi erat dengan <a href={partnerUrl} target="_blank">cukurukuk.co</a>.
            </p>

            <h3>Infrastruktur Berkecepatan Tinggi</h3>
            <p>
                Setiap detik dalam pertandingan sepak bola adalah momentum berharga. Oleh karena itu, JALALIVE yang didukung penuh oleh infrastruktur <a href={partnerUrl} target="_blank">cukurukuk.co</a>, menggunakan server dengan latensi rendah untuk memastikan siaran berjalan stabil. Teknologi Astro v4 yang kami terapkan memungkinkan website ini beroperasi tanpa beban JavaScript yang berat, sehingga akses melalui perangkat seluler sekalipun akan terasa sangat ringan dan responsif, bahkan di area dengan koneksi internet terbatas.
            </p>

            <h3>Cakupan Liga dan Turnamen Global HD</h3>
            <p>
                Kami menyadari bahwa kecintaan terhadap sepak bola tidak mengenal batas wilayah. Di JALALIVE, Anda akan menemukan kompilasi jadwal dari lebih 15 liga elit dunia secara harian. Mulai dari panasnya persaingan Premier League di Inggris, keanggunan taktis Serie A di Italia, hingga drama luar biasa di Liga Champions Eropa. Semua jadwal ini disusun secara sistematis agar Anda tidak melewatkan satu pun kick-off penting dari tim kesayangan Anda. Melalui integrasi dengan <a href={partnerUrl} target="_blank">cukurukuk.co</a>, kualitas visual yang dihadirkan selalu terjaga pada standar definisi tinggi.
            </p>

            <h3>Kualitas Visual dan Standar Keamanan Digital</h3>
            <p>
                Memberikan akses gratis bukan berarti kami menurunkan standar kualitas. Setiap link yang tersedia di platform kami dirancang untuk mendukung resolusi High Definition (HD) yang memberikan ketajaman gambar maksimal. Selain dari sisi visual, kami juga sangat memperhatikan aspek keamanan digital. Sesuai dengan permintaan privasi, platform ini dilengkapi dengan sistem proteksi tingkat tinggi yang mencegah penggandaan konten secara ilegal. Pengalaman menonton di JALALIVE yang terafiliasi dengan <a href={partnerUrl} target="_blank">cukurukuk.co</a> menjamin ekosistem yang tetap aman dan terpercaya bagi semua pengunjung tanpa gangguan elemen eksternal yang tidak perlu.
            </p>

            <h3>Visi Menuju Masa Depan Streaming Interaktif</h3>
            <p>
                Ke depannya, JALALIVE berkomitmen untuk terus berinovasi dalam penyediaan konten olahraga yang lebih interaktif. Dengan tetap mempertahankan estetika modern dan ketiadaan elemen yang mengganggu seperti favicon yang tidak perlu atau iklan pop-up yang agresif, kami ingin membangun standar baru dalam industri streaming bola di Indonesia. Dukungan dari <a href={partnerUrl} target="_blank">cukurukuk.co</a> memungkinkan kami untuk terus memperluas bandwidth server demi kenyamanan Anda. Bergabunglah bersama komunitas kami dan rasakan bedanya menonton bola dengan standar profesional yang hanya bisa Anda dapatkan di sini.
            </p>
        </article>
    </main>

    <footer style="text-align: center; padding: 50px; color: #222; font-size: 0.7rem; border-top: 1px solid #111;">
        &copy; 2026 JALALIVE. Supported by <a href={partnerUrl} style="color:#333; text-decoration:none;">cukurukuk.co</a>. No Favicon Applied.
    </footer>

    <script is:inline>
        // Anti F12, Ctrl+U, Klik Kanan (Proteksi Penuh)
        document.addEventListener('contextmenu', e => e.preventDefault());
        document.onkeydown = function(e) {
            if (e.keyCode == 123 || (e.ctrlKey && (e.keyCode == 'U'.charCodeAt(0) || e.keyCode == 'I'.charCodeAt(0) || e.keyCode == 'S'.charCodeAt(0) || e.keyCode == 'C'.charCodeAt(0)))) {
                return false;
            }
        };
    </script>
</body>
</html>