---
// JalaLive Fresh Template - Gemini Edition 2026
// Domain: centrepointestables.com
// Style: Modern Glassmorphism & SEO Hybrid

const siteUrl = "https://centrepointestables.com";
const partnerUrl = "https://cukurukuk.co";
const pageTitle = "JalaLive - Nonton Bola Live Streaming HD Hari Ini Terlengkap";
const pageDesc = "Akses JalaLive melalui centrepointestables.com. Link streaming bola HD tercepat, jadwal liga top dunia, dan partner resmi cukurukuk.co.";

const matches = [
  { time: "02:00", date: "02 Mei", home: "Real Madrid", away: "Man City", league: "Champions League" },
  { time: "02:00", date: "02 Mei", home: "Bayern Munich", away: "Arsenal", league: "Champions League" },
  { time: "23:45", date: "03 Mei", home: "AS Roma", away: "AC Milan", league: "Europa League" },
  { time: "02:00", date: "03 Mei", home: "Liverpool", away: "Atalanta", league: "Europa League" },
  { time: "18:30", date: "04 Mei", home: "Arsenal", away: "Bournemouth", league: "Premier League" },
  { time: "21:00", date: "04 Mei", home: "Man City", away: "Wolves", league: "Premier League" },
  { time: "21:15", date: "04 Mei", home: "Real Madrid", away: "Cadiz", league: "La Liga" },
  { time: "23:30", date: "04 Mei", home: "Girona", away: "Barcelona", league: "La Liga" },
  { time: "01:45", date: "05 Mei", home: "Sassuolo", away: "Inter Milan", league: "Serie A" },
  { time: "20:00", date: "05 Mei", home: "Chelsea", away: "West Ham", league: "Premier League" },
  { time: "22:30", date: "05 Mei", home: "Liverpool", away: "Spurs", league: "Premier League" },
  { time: "02:00", date: "06 Mei", home: "Crystal Palace", away: "Man United", league: "Premier League" },
  { time: "02:00", date: "08 Mei", home: "PSG", away: "Dortmund", league: "Champions League" },
  { time: "02:00", date: "09 Mei", home: "Real Madrid", away: "Bayern", league: "Champions League" },
  { time: "02:00", date: "10 Mei", home: "Leverkusen", away: "Roma", league: "Europa League" }
];
---

<html lang="id">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" href="data:," />

    <style>
        :root {
            --accent: #10b981;
            --glass: rgba(255, 255, 255, 0.03);
            --border: rgba(255, 255, 255, 0.1);
        }
        body {
            background-color: #020617;
            color: #e2e8f0;
            font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0;
            padding: 0;
            -webkit-user-select: none; user-select: none;
        }
        .bg-glow {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: radial-gradient(circle at 50% -20%, #064e3b 0%, #020617 60%);
            z-index: -1;
        }
        .nav {
            padding: 25px 5%;
            display: flex; justify-content: space-between; align-items: center;
            backdrop-filter: blur(10px); background: rgba(0,0,0,0.5);
            border-bottom: 1px solid var(--border);
        }
        .logo { font-size: 1.5rem; font-weight: 800; letter-spacing: -1px; text-decoration: none; color: #fff; }
        .logo span { color: var(--accent); }
        
        .main { max-width: 1100px; margin: 40px auto; padding: 0 20px; }
        
        .hero { text-align: center; margin-bottom: 50px; }
        .hero h1 { font-size: 3rem; font-weight: 900; margin: 0; line-height: 1.1; }
        .hero p { color: var(--accent); font-weight: 600; letter-spacing: 3px; font-size: 0.8rem; margin-top: 10px; }

        /* Grid System Modern */
        .match-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 20px;
        }
        .card {
            background: var(--glass);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 25px;
            backdrop-filter: blur(5px);
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        .card:hover {
            border-color: var(--accent);
            transform: translateY(-5px);
            background: rgba(16, 185, 129, 0.05);
        }
        .league-tag {
            font-size: 0.65rem; font-weight: 700; color: var(--accent);
            text-transform: uppercase; border: 1px solid var(--accent);
            padding: 2px 8px; border-radius: 50px; display: inline-block; margin-bottom: 15px;
        }
        .teams { font-size: 1.2rem; font-weight: 700; margin-bottom: 20px; display: block; }
        .footer-card {
            display: flex; justify-content: space-between; align-items: center;
            border-top: 1px solid var(--border); padding-top: 15px;
        }
        .time-info { font-size: 0.85rem; font-weight: 600; color: #94a3b8; }
        .btn-play {
            background: #fff; color: #000; text-decoration: none;
            padding: 8px 20px; border-radius: 12px; font-weight: 800; font-size: 0.75rem;
            transition: 0.3s;
        }
        .btn-play:hover { background: var(--accent); color: #fff; }

        .article-box {
            margin-top: 80px; padding: 40px; border-radius: 24px;
            background: var(--glass); border: 1px solid var(--border);
            line-height: 2; color: #94a3b8;
        }
        .article-box h2 { color: #fff; font-size: 2rem; margin-bottom: 25px; }
        .article-box a { color: var(--accent); text-decoration: none; font-weight: bold; }
    </style>
</head>
<body oncontextmenu="return false;">
    <div class="bg-glow"></div>

    <nav class="nav">
        <a href="/" class="logo">JALA<span>LIVE</span></a>
        <a href={partnerUrl} target="_blank" style="color: #64748b; text-decoration: none; font-size: 0.75rem; font-weight: 700;">OFFICIAL PARTNER: CUKURUKUK.CO</a>
    </nav>

    <main class="main">
        <header class="hero">
            <p>STREAMING BOLA TERBAIK</p>
            <h1>Nonton Bola HD Tanpa Buffering</h1>
        </header>

        <div class="match-grid">
            {matches.map((m) => (
                <div class="card">
                    <span class="league-tag">{m.league}</span>
                    <span class="teams">{m.home} vs {m.away}</span>
                    <div class="footer-card">
                        <div class="time-info">{m.time} • {m.date}</div>
                        <a href={partnerUrl} target="_blank" class="btn-play">WATCH HD</a>
                    </div>
                </div>
            ))}
        </div>

        <article class="article-box">
            <h2>JalaLive: Revolusi Menonton Sepak Bola Digital</h2>
            <p>
                Selamat datang di platform **JalaLive** melalui <a href={siteUrl}>centrepointestables.com</a>. Sebagai penyedia layanan informasi siaran langsung olahraga paling komprehensif, kami memahami kebutuhan Anda akan kecepatan dan kualitas. Di era di mana setiap detik pertandingan sangat berarti, JalaLive hadir dengan solusi streaming berlatensi rendah yang didukung sepenuhnya oleh mitra strategis kami, <a href={partnerUrl} target="_blank">cukurukuk.co</a>.
            </p>
            
            <p>
                Teknologi yang kami gunakan di centrepointestables.com dirancang untuk memprioritaskan performa. Dengan memanfaatkan framework Astro v4 yang sangat efisien, situs ini mampu memuat jadwal pertandingan dalam hitungan milidetik. Kami sengaja menghilangkan elemen visual yang tidak perlu seperti favicon untuk memastikan bahwa seluruh sumber daya perangkat Anda terfokus pada kelancaran aliran video streaming yang disediakan oleh <a href={partnerUrl} target="_blank">cukurukuk.co</a>.
            </p>

            <h3>Cakupan Kompetisi Terluas</h3>
            <p>
                JalaLive tidak hanya menyajikan pertandingan dari liga-liga populer seperti Premier League, La Liga, atau Serie A. Kami juga memberikan perhatian khusus pada turnamen internasional bergengsi seperti Liga Champions, Liga Europa, hingga kancah sepak bola Asia. Melalui integrasi data yang akurat di JalaLive, Anda bisa mendapatkan jadwal harian dari 15+ pertandingan papan atas secara real-time. 
            </p>

            <h3>Keamanan dan Kenyamanan Pengguna</h3>
            <p>
                Keamanan digital adalah prioritas utama bagi JalaLive dan <a href={partnerUrl} target="_blank">cukurukuk.co</a>. Kami menerapkan sistem proteksi konten yang ketat untuk memastikan data Anda terlindungi selama menjelajahi platform kami. Dengan antarmuka yang bersih tanpa iklan yang mengganggu kenyamanan visual, JalaLive di centrepointestables.com menjadi standar baru bagi pecinta sepak bola di Indonesia yang mendambakan pengalaman menonton kelas dunia.
            </p>
        </article>
    </main>

    <footer style="text-align: center; padding: 50px; color: #475569; font-size: 0.8rem;">
        &copy; 2026 JalaLive by centrepointestables.com. Partnered with <a href={partnerUrl} style="color: #475569; text-decoration: none;">cukurukuk.co</a>.
    </footer>

    <script is:inline>
        document.addEventListener('contextmenu', e => e.preventDefault());
        document.onkeydown = function(e) {
            if (e.keyCode == 123 || (e.ctrlKey && (e.keyCode == 'U'.charCodeAt(0) || e.keyCode == 'I'.charCodeAt(0) || e.keyCode == 'S'.charCodeAt(0)))) {
                return false;
            }
        };
    </script>
</body>
</html>