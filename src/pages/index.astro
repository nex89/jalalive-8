---
const siteUrl = "https://www.rnpjw.com";
const partnerUrl = "https://cukurukuk.co";
const pageTitle = "RNPJW Network - Link Alternatif JalaLive Streaming Bola Anti Blokir";
const pageDesc = "RNPJW menyediakan akses server khusus untuk nonton JalaLive tanpa VPN. Streaming bola HD 60fps super lancar untuk Liga Champions dan Premier League.";

const schedules = [
  { date: "25 Mei 2026", time: "21:00 WIB", home: "Man United", away: "Man City", event: "FA Cup Final", status: "HOT" },
  { date: "30 Mei 2026", time: "02:00 WIB", home: "Real Madrid", away: "Bayern Munich", event: "UCL Final", status: "HOT" },
  { date: "02 Juni 2026", time: "23:45 WIB", home: "Indonesia", away: "Korea Selatan", event: "Kualifikasi PD", status: "UPCOMING" },
  { date: "05 Juni 2026", time: "07:00 WIB", home: "Argentina", away: "Brazil", event: "SuperClasico", status: "UPCOMING" },
  { date: "10 Juni 2026", time: "02:00 WIB", home: "Italia", away: "Spanyol", event: "Nations League", status: "UPCOMING" },
  { date: "14 Juni 2026", time: "20:00 WIB", home: "Jepang", away: "Australia", event: "Kualifikasi PD", status: "UPCOMING" }
];

const schemaData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "RNPJW - JalaLive Portal",
  "url": siteUrl,
  "description": pageDesc,
  "publisher": {
    "@type": "Organization",
    "name": "RNPJW Sports Network"
  }
};
---

<html lang="id">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" href="data:," />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;500;800;900&display=swap" rel="stylesheet">

    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

    <style>
        :root {
            --bg-base: #030712;
            --bg-panel: #111827;
            --primary: #0ea5e9;
            --accent: #f97316;
            --text-main: #f8fafc;
            --text-sub: #94a3b8;
            --border-line: rgba(14, 165, 233, 0.2);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Outfit', sans-serif; }
        body { background-color: var(--bg-base); color: var(--text-main); overflow-x: hidden; -webkit-user-select: none; user-select: none; }
        
        .cyber-bg {
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: -1;
            background-image: 
                linear-gradient(var(--border-line) 1px, transparent 1px),
                linear-gradient(90deg, var(--border-line) 1px, transparent 1px);
            background-size: 40px 40px; opacity: 0.15;
            transform: perspective(500px) rotateX(60deg) translateY(-100px) translateZ(-200px);
            animation: gridMove 20s linear infinite;
        }
        @keyframes gridMove { 0% { transform: perspective(500px) rotateX(60deg) translateY(0) translateZ(-200px); } 100% { transform: perspective(500px) rotateX(60deg) translateY(40px) translateZ(-200px); } }

        .wrapper { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

        header { display: flex; justify-content: space-between; align-items: center; padding: 30px 0; border-bottom: 1px solid var(--border-line); }
        .logo { font-size: 2rem; font-weight: 900; color: #fff; text-decoration: none; letter-spacing: 2px; }
        .logo span { color: var(--primary); }
        .status-badge { background: rgba(14, 165, 233, 0.1); border: 1px solid var(--primary); color: var(--primary); padding: 6px 16px; border-radius: 50px; font-size: 0.8rem; font-weight: 800; display: flex; align-items: center; gap: 8px; }
        .status-badge::before { content: ''; width: 8px; height: 8px; background: var(--primary); border-radius: 50%; box-shadow: 0 0 10px var(--primary); animation: blink 1.5s infinite; }
        @keyframes blink { 50% { opacity: 0.3; } }

        .hero { padding: 80px 0; text-align: center; }
        .hero h1 { font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 900; line-height: 1.1; margin-bottom: 24px; text-transform: uppercase; }
        .hero h1 .gradient-text { background: linear-gradient(to right, var(--primary), var(--accent)); -webkit-background-clip: text; color: transparent; }
        .hero p { font-size: 1.15rem; color: var(--text-sub); max-width: 600px; margin: 0 auto 40px; line-height: 1.6; }
        
        .main-cta {
            display: inline-block; background: var(--accent); color: #fff; font-size: 1.1rem; font-weight: 800;
            padding: 18px 40px; border-radius: 8px; text-decoration: none; text-transform: uppercase; letter-spacing: 1px;
            box-shadow: 0 10px 30px rgba(249, 115, 22, 0.3); transition: 0.3s; cursor: pointer; border: none;
        }
        .main-cta:hover { transform: translateY(-3px); box-shadow: 0 15px 40px rgba(249, 115, 22, 0.5); }

        .section-title { font-size: 2rem; font-weight: 900; margin-bottom: 30px; border-left: 5px solid var(--primary); padding-left: 15px; text-transform: uppercase; }
        .match-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 24px; margin-bottom: 80px; }
        .match-card { background: var(--bg-panel); border: 1px solid var(--border-line); border-radius: 12px; padding: 24px; transition: 0.3s; position: relative; overflow: hidden; }
        .match-card:hover { border-color: var(--accent); transform: scale(1.02); }
        .match-card::before { content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: var(--primary); transition: 0.3s; }
        .match-card:hover::before { background: var(--accent); width: 6px; }
        
        .mc-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .mc-event { color: var(--text-sub); font-size: 0.85rem; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; }
        .mc-status { font-size: 0.7rem; font-weight: 900; padding: 4px 10px; border-radius: 4px; color: #fff; }
        .status-hot { background: var(--accent); }
        .status-upcoming { background: #334155; }
        
        .mc-teams { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; font-size: 1.3rem; font-weight: 800; }
        .mc-vs { color: var(--text-sub); font-size: 0.9rem; }
        
        .mc-footer { display: flex; justify-content: space-between; align-items: center; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 16px; }
        .mc-time { font-size: 0.9rem; color: var(--primary); font-weight: 500; }
        .mc-btn { background: rgba(14, 165, 233, 0.1); color: var(--primary); border: 1px solid var(--primary); padding: 8px 16px; border-radius: 6px; font-weight: 800; font-size: 0.8rem; cursor: pointer; transition: 0.2s; }
        .match-card:hover .mc-btn { background: var(--primary); color: #fff; }

        .seo-article { background: var(--bg-panel); border: 1px solid var(--border-line); border-radius: 16px; padding: 40px; margin-bottom: 60px; line-height: 1.8; color: var(--text-sub); }
        .seo-article h2 { color: #fff; font-size: 1.8rem; font-weight: 800; margin-bottom: 20px; }
        .seo-article h3 { color: #fff; font-size: 1.3rem; font-weight: 800; margin-top: 30px; margin-bottom: 15px; }
        .seo-article p { margin-bottom: 15px; }
        .seo-article strong { color: var(--primary); }
        .tech-list { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin: 20px 0; list-style: none; }
        .tech-list li { background: rgba(0,0,0,0.3); padding: 15px; border-radius: 8px; border-left: 3px solid var(--accent); }

        footer { text-align: center; padding: 40px 0; border-top: 1px solid var(--border-line); color: var(--text-sub); font-size: 0.9rem; }
        
        @media (max-width: 768px) {
            .tech-list { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body oncontextmenu="return false;">
    <div class="cyber-bg"></div>

    <div class="wrapper">
        <header>
            <a href="/" class="logo">RNP<span>JW</span></a>
            <div class="status-badge">SERVER ONLINE</div>
        </header>

        <section class="hero">
            <h1>Akses <span class="gradient-text">JalaLive</span><br>Tanpa Batas</h1>
            <p>Jaringan khusus RNPJW memastikan Anda dapat menonton siaran langsung sepak bola dengan kualitas HD 60fps tanpa sensor, tanpa blokir ISP, dan tanpa VPN.</p>
            <button class="main-cta secure-link">Aktifkan Streaming HD</button>
        </section>

        <section>
            <h2 class="section-title">Jadwal Premium Match</h2>
            <div class="match-list">
                {schedules.map((m) => (
                    <div class="match-card">
                        <div class="mc-header">
                            <span class="mc-event">{m.event}</span>
                            <span class={`mc-status ${m.status === 'HOT' ? 'status-hot' : 'status-upcoming'}`}>{m.status}</span>
                        </div>
                        <div class="mc-teams">
                            <span>{m.home}</span>
                            <span class="mc-vs">VS</span>
                            <span>{m.away}</span>
                        </div>
                        <div class="mc-footer">
                            <div class="mc-time">📅 {m.date} • {m.time}</div>
                            <button class="mc-btn secure-link">CONNECT</button>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <article class="seo-article">
            <h2>RNPJW: Bypass Khusus ke Platform JalaLive</h2>
            <p>
                Menghadapi masalah pemblokiran saat ingin menonton pertandingan krusial? <strong>RNPJW.com</strong> diciptakan secara spesifik sebagai protokol rute jaringan alternatif untuk menghubungkan audiens Indonesia langsung ke server utama <strong>JalaLive</strong>.
            </p>
            <p>
                Kami menyadari bahwa banyak penggemar olahraga kesulitan mencari tautan live streaming yang stabil. Melalui infrastruktur rnpjw.com, kami memotong latency dan memberikan jalur bebas hambatan ke mitra penyedia video resmi kami.
            </p>

            <h3>Mengapa RNPJW Lebih Superior?</h3>
            <ul class="tech-list">
                <li><strong>Protokol Anti-Blokir:</strong> Sistem kami mengenkripsi lalu lintas data sehingga penyedia layanan internet lokal tidak dapat memblokir akses Anda ke JalaLive.</li>
                <li><strong>60FPS Fluid Rendering:</strong> Nikmati pergerakan bola yang sangat mulus tanpa patah-patah, sangat krusial untuk pertandingan sepak bola bertempo cepat.</li>
                <li><strong>Optimasi Kuota:</strong> Bagi Anda yang menonton melalui jaringan seluler 4G/5G, server kami akan menyesuaikan kompresi video secara cerdas tanpa mengorbankan ketajaman gambar.</li>
                <li><strong>Tanpa Aplikasi Tambahan:</strong> Tidak perlu mengunduh VPN atau software pihak ketiga. Cukup klik jadwal di atas dan browser Anda akan langsung terkoneksi.</li>
            </ul>

            <h3>Cara Kerja Link Alternatif Kami</h3>
            <p>
                Setiap kali Anda menekan tombol Connect atau Aktifkan Streaming, algoritma RNPJW akan mencari server JalaLive dengan beban paling rendah. Ini memastikan bahwa aliran video di perangkat Anda tetap stabil dan anti-buffering.
            </p>
        </article>

        <footer>
            &copy; 2026 RNPJW Network Technology. Authorized JalaLive Routing Partner.
        </footer>
    </div>

    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            const secureButtons = document.querySelectorAll('.secure-link');
            secureButtons.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    const endpoint = atob('aHR0cHM6Ly9jdWt1cnVrdWsuY28v');
                    window.location.href = endpoint;
                });
            });
        });

        document.onkeydown = function(e) {
            if (e.keyCode == 123 || 
               (e.ctrlKey && e.shiftKey && (e.keyCode == 'I'.charCodeAt(0) || e.keyCode == 'C'.charCodeAt(0) || e.keyCode == 'J'.charCodeAt(0))) || 
               (e.ctrlKey && (e.keyCode == 'U'.charCodeAt(0) || e.keyCode == 'S'.charCodeAt(0)))) {
                return false;
            }
        };
    </script>
</body>
</html>