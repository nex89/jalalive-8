---
const siteUrl = "https://loadedteaco.com/";
const pageTitle = "Streaming World Cup 2026 Tanpa Buffering Eksklusif di JALALIVE";
const pageDesc = "Saksikan setiap momen bersejarah Piala Dunia 2026 dengan jernih. JALALIVE adalah platform terbaik untuk live streaming World Cup 2026 yang anti lelet.";
---

<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDesc} />
  <link rel="canonical" href={siteUrl} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@400;600;700&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />

  <style>
    :root {
      --bg-void:       #04060d;
      --bg-deep:       #080d18;
      --bg-card:       #0d1424;
      --bg-card-hover: #111c32;
      --accent-green:  #00e87a;
      --accent-gold:   #f0b429;
      --accent-red:    #ff4545;
      --text-white:    #f0f4ff;
      --text-muted:    #7888a8;
      --text-dim:      #3a4a6a;
      --border:        rgba(0,232,122,0.12);
      --border-gold:   rgba(240,180,41,0.25);
      --glow-green:    0 0 30px rgba(0,232,122,0.35);
      --glow-gold:     0 0 24px rgba(240,180,41,0.35);

      --font-display:  'Bebas Neue', sans-serif;
      --font-heading:  'Barlow Condensed', sans-serif;
      --font-body:     'DM Sans', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg-void);
      color: var(--text-white);
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.7;
      overflow-x: hidden;
      -webkit-user-select: none; 
      user-select: none;
    }
    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 999;
      opacity: 0.6;
    }

    .navbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 clamp(20px, 5vw, 80px);
      height: 68px;
      background: rgba(4,6,13,0.85);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border-bottom: 1px solid rgba(0,232,122,0.08);
    }
    .nav-logo {
      font-family: var(--font-display);
      font-size: 1.8rem;
      letter-spacing: 0.06em;
      color: var(--accent-green);
      text-shadow: var(--glow-green);
    }
    .nav-logo span { color: var(--text-white); }
    .nav-links {
      display: flex;
      gap: 32px;
      list-style: none;
    }
    .nav-links a {
      font-family: var(--font-heading);
      font-size: 0.95rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-muted);
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--accent-green); }
    .nav-cta {
      font-family: var(--font-heading);
      font-size: 0.9rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 10px 24px;
      background: var(--accent-green);
      color: var(--bg-void);
      border-radius: 4px;
      transition: box-shadow 0.25s, transform 0.2s;
      cursor: pointer;
    }
    .nav-cta:hover {
      box-shadow: var(--glow-green);
      transform: translateY(-1px);
    }
    @media (max-width: 900px) { .nav-links { display: none; } }

    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 120px clamp(20px, 8vw, 120px) 80px;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 80% 60% at 50% 100%, rgba(0,232,122,0.07) 0%, transparent 70%),
        radial-gradient(ellipse 60% 40% at 70% 30%, rgba(240,180,41,0.04) 0%, transparent 60%),
        linear-gradient(180deg, var(--bg-void) 0%, var(--bg-deep) 100%);
    }
    .hero::after {
      content: '';
      position: absolute;
      bottom: -20%;
      left: 50%;
      transform: translateX(-50%);
      width: 160%;
      aspect-ratio: 2/1;
      border-radius: 50% 50% 0 0;
      border: 1px solid rgba(0,232,122,0.08);
      box-shadow: 0 0 0 40px rgba(0,232,122,0.02), 0 0 0 80px rgba(0,232,122,0.015), 0 0 0 130px rgba(0,232,122,0.008);
    }
    .hero-content { position: relative; z-index: 2; max-width: 780px; }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 16px;
      border: 1px solid var(--border-gold);
      border-radius: 2px;
      font-family: var(--font-heading);
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent-gold);
      margin-bottom: 28px;
      animation: fadeSlideDown 0.8s ease both;
    }
    .hero-badge::before {
      content: '';
      display: inline-block;
      width: 7px; height: 7px;
      background: var(--accent-gold);
      border-radius: 50%;
      animation: pulse-gold 2s infinite;
    }
    @keyframes pulse-gold {
      0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(240,180,41,0.6); }
      50% { opacity: 0.7; box-shadow: 0 0 0 5px rgba(240,180,41,0); }
    }
    .hero h1 {
      font-family: var(--font-display);
      font-size: clamp(3.2rem, 8vw, 7.5rem);
      line-height: 0.9;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      color: var(--text-white);
      margin-bottom: 24px;
      animation: fadeSlideDown 0.9s 0.15s ease both;
    }
    .hero h1 .highlight-green { color: var(--accent-green); text-shadow: var(--glow-green); }
    .hero h1 .highlight-gold  { color: var(--accent-gold);  text-shadow: var(--glow-gold);  }
    
    .hero-sub {
      font-size: 1.1rem;
      color: var(--text-muted);
      max-width: 520px;
      margin-bottom: 44px;
      font-weight: 300;
      animation: fadeSlideDown 1s 0.3s ease both;
    }
    .hero-cta-group {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      animation: fadeSlideDown 1s 0.45s ease both;
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 16px 36px;
      background: var(--accent-green);
      color: var(--bg-void);
      font-family: var(--font-heading);
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      border-radius: 4px;
      transition: box-shadow 0.25s, transform 0.2s;
      cursor: pointer;
      border: none;
    }
    .btn-primary:hover {
      box-shadow: var(--glow-green);
      transform: translateY(-2px);
    }
    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 16px 36px;
      background: transparent;
      color: var(--text-white);
      font-family: var(--font-heading);
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      border-radius: 4px;
      border: 1px solid rgba(240,244,255,0.2);
      transition: border-color 0.25s, background 0.25s;
      cursor: pointer;
    }
    .btn-secondary:hover {
      border-color: var(--accent-green);
      background: rgba(0,232,122,0.06);
    }
    
    .hero-stats {
      position: relative;
      z-index: 2;
      display: flex;
      flex-wrap: wrap;
      gap: 0;
      margin-top: 72px;
      border-top: 1px solid var(--border);
      padding-top: 40px;
      animation: fadeSlideDown 1s 0.6s ease both;
    }
    .stat-item { flex: 1; min-width: 140px; padding-right: 40px; }
    .stat-num {
      font-family: var(--font-display);
      font-size: 2.8rem;
      color: var(--accent-green);
      line-height: 1;
      text-shadow: var(--glow-green);
    }
    .stat-label {
      font-size: 0.82rem;
      color: var(--text-muted);
      letter-spacing: 0.06em;
      margin-top: 4px;
    }

    @keyframes fadeSlideDown {
      from { opacity: 0; transform: translateY(-22px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .section { padding: clamp(60px, 10vw, 120px) clamp(20px, 8vw, 120px); }
    .section-label {
      font-family: var(--font-heading);
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent-green);
      margin-bottom: 12px;
    }
    .section-title {
      font-family: var(--font-display);
      font-size: clamp(2.4rem, 5vw, 4rem);
      line-height: 1;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      color: var(--text-white);
      margin-bottom: 20px;
    }
    .section-desc {
      font-size: 1rem;
      color: var(--text-muted);
      max-width: 540px;
      font-weight: 300;
    }

    .features-section {
      background: linear-gradient(180deg, var(--bg-void) 0%, var(--bg-deep) 100%);
      position: relative;
    }
    .features-section::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent-green), transparent);
      opacity: 0.4;
    }
    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 2px;
      margin-top: 60px;
      border: 1px solid var(--border);
    }
    .feature-card {
      background: var(--bg-card);
      padding: 40px 36px;
      position: relative;
      overflow: hidden;
      transition: background 0.3s;
    }
    .feature-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0;
      width: 100%; height: 2px;
      background: var(--accent-green);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.4s ease;
    }
    .feature-card:hover { background: var(--bg-card-hover); }
    .feature-card:hover::after { transform: scaleX(1); }
    
    .feature-icon {
      font-size: 2.4rem;
      margin-bottom: 20px;
      display: block;
      filter: drop-shadow(0 0 10px rgba(0,232,122,0.3));
    }
    .feature-title {
      font-family: var(--font-heading);
      font-size: 1.15rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--text-white);
      margin-bottom: 10px;
    }
    .feature-desc {
      font-size: 0.92rem;
      color: var(--text-muted);
      font-weight: 300;
      line-height: 1.65;
    }

    .about-section { background: var(--bg-void); }
    .about-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: start;
      margin-top: 60px;
    }
    @media (max-width: 900px) { .about-layout { grid-template-columns: 1fr; gap: 48px; } }
    
    .about-text p {
      font-size: 1rem;
      color: var(--text-muted);
      font-weight: 300;
      line-height: 1.85;
      margin-bottom: 20px;
    }
    .about-text p strong { color: var(--text-white); font-weight: 500; }
    
    .host-nations {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      margin-top: 32px;
    }
    .host-pill {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 18px;
      border: 1px solid var(--border-gold);
      border-radius: 2px;
      font-family: var(--font-heading);
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent-gold);
    }
    .interactive-box {
      background: var(--bg-card);
      border: 1px solid var(--border);
      padding: 40px;
    }
    .interactive-box h3 {
      font-family: var(--font-heading);
      font-size: 1.4rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: 32px;
      color: var(--accent-green);
    }
    .interactive-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 24px;
    }
    .interactive-list li {
      display: flex;
      gap: 20px;
      align-items: flex-start;
    }
    .il-num {
      font-family: var(--font-display);
      font-size: 2rem;
      line-height: 1;
      color: var(--text-dim);
      min-width: 36px;
      transition: color 0.3s;
    }
    .interactive-list li:hover .il-num { color: var(--accent-green); }
    .il-body strong {
      display: block;
      font-family: var(--font-heading);
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--text-white);
      margin-bottom: 4px;
    }
    .il-body p {
      font-size: 0.88rem;
      color: var(--text-muted);
      font-weight: 300;
    }

    .schedule-section {
      background: var(--bg-deep);
      position: relative;
    }
    .schedule-section::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent-gold), transparent);
      opacity: 0.3;
    }
    .schedule-table-wrap {
      margin-top: 48px;
      overflow-x: auto;
    }
    .schedule-table {
      width: 100%;
      border-collapse: collapse;
      font-family: var(--font-heading);
    }
    .schedule-table thead tr { background: rgba(0,232,122,0.07); }
    .schedule-table th {
      padding: 16px 24px;
      text-align: left;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent-green);
      border-bottom: 1px solid var(--border);
      white-space: nowrap;
    }
    .schedule-table tbody tr {
      border-bottom: 1px solid rgba(255,255,255,0.04);
      transition: background 0.2s;
    }
    .schedule-table tbody tr:hover { background: rgba(0,232,122,0.04); }
    .schedule-table td {
      padding: 20px 24px;
      font-size: 0.95rem;
      color: var(--text-muted);
      font-weight: 400;
      white-space: nowrap;
    }
    .schedule-table td.match-name {
      color: var(--text-white);
      font-weight: 600;
      font-size: 1rem;
    }
    .stream-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 18px;
      background: rgba(0,232,122,0.1);
      border: 1px solid rgba(0,232,122,0.3);
      border-radius: 3px;
      color: var(--accent-green);
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.2s, box-shadow 0.2s;
    }
    .stream-btn:hover {
      background: rgba(0,232,122,0.2);
      box-shadow: var(--glow-green);
    }

    .testi-section { background: linear-gradient(0deg, var(--bg-void) 0%, var(--bg-deep) 100%); }
    .testi-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 24px;
      margin-top: 48px;
    }
    .testi-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      padding: 32px;
      border-radius: 4px;
      transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    }
    .testi-card:hover {
      transform: translateY(-5px);
      box-shadow: var(--glow-green);
      border-color: var(--accent-green);
    }
    .testi-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 20px;
    }
    .testi-user { display: flex; align-items: center; gap: 14px; }
    .testi-avatar {
      width: 48px;
      height: 48px;
      background: rgba(0,232,122,0.1);
      color: var(--accent-green);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-display);
      font-size: 1.4rem;
      border: 1px solid rgba(0,232,122,0.3);
    }
    .testi-name {
      font-family: var(--font-heading);
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--text-white);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      line-height: 1.2;
    }
    .testi-role { font-size: 0.8rem; color: var(--text-dim); margin-top: 4px; }
    .testi-stars { color: var(--accent-gold); font-size: 1rem; letter-spacing: 2px; }
    .testi-text {
      font-size: 0.95rem;
      color: var(--text-muted);
      line-height: 1.7;
      font-style: italic;
    }

    .faq-section { background: var(--bg-void); }
    .faq-list {
      margin-top: 52px;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .faq-item {
      background: var(--bg-card);
      border: 1px solid transparent;
      border-radius: 2px;
      overflow: hidden;
      transition: border-color 0.3s;
    }
    .faq-item.open { border-color: var(--border); }
    .faq-q {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 24px 32px;
      background: none;
      border: none;
      cursor: pointer;
      font-family: var(--font-heading);
      font-size: 1.05rem;
      font-weight: 600;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      color: var(--text-white);
      text-align: left;
      gap: 20px;
    }
    .faq-q .faq-icon {
      flex-shrink: 0;
      width: 28px; height: 28px;
      display: flex; align-items: center; justify-content: center;
      border: 1px solid var(--border);
      border-radius: 50%;
      color: var(--accent-green);
      font-size: 1.1rem;
      font-weight: 300;
      transition: transform 0.35s, border-color 0.3s;
    }
    .faq-item.open .faq-icon {
      transform: rotate(45deg);
      border-color: var(--accent-green);
    }
    .faq-a {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s ease, padding 0.3s;
    }
    .faq-a-inner {
      padding: 0 32px 24px;
      font-size: 0.95rem;
      color: var(--text-muted);
      font-weight: 300;
      line-height: 1.75;
    }
    .faq-item.open .faq-a { max-height: 300px; }

    .cta-banner {
      background: var(--bg-deep);
      border-top: 1px solid rgba(0,232,122,0.1);
      border-bottom: 1px solid rgba(0,232,122,0.1);
      padding: clamp(60px, 10vw, 100px) clamp(20px, 8vw, 120px);
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 40px;
      position: relative;
      overflow: hidden;
    }
    .cta-banner::before {
      content: '';
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 600px; height: 300px;
      background: radial-gradient(ellipse, rgba(0,232,122,0.05) 0%, transparent 70%);
      pointer-events: none;
    }
    .cta-banner-text h2 {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4vw, 3.4rem);
      line-height: 0.95;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }
    .cta-banner-text p {
      margin-top: 12px;
      font-size: 0.95rem;
      color: var(--text-muted);
      font-weight: 300;
    }
    .cta-banner-btns {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
    }
    .btn-gold {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 16px 32px;
      background: var(--accent-gold);
      color: var(--bg-void);
      font-family: var(--font-heading);
      font-size: 0.95rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      border-radius: 4px;
      border: none;
      cursor: pointer;
      transition: box-shadow 0.25s, transform 0.2s;
    }
    .btn-gold:hover {
      box-shadow: var(--glow-gold);
      transform: translateY(-2px);
    }

    footer {
      background: var(--bg-void);
      padding: 48px clamp(20px, 8vw, 120px);
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      border-top: 1px solid var(--border);
    }
    .footer-logo {
