---
const siteUrl = "https://www.instantradiostation.com";
const partnerUrl = "https://cukurukuk.co";
const pageTitle = "JalaLive - Link Nonton Live Streaming Bola HD Tercepat";
const pageDesc = "JalaLive adalah situs nonton live streaming bola HD tanpa buffering. Cek jadwal lengkap Liga Inggris, Liga Champions, dan akses link alternatif JalaLive terbaru.";

const matches = [
  { time: "02:00", date: "02 Mei", home: "Real Madrid", away: "Man City", league: "Champions League" },
  { time: "23:45", date: "03 Mei", home: "AS Roma", away: "AC Milan", league: "Europa League" },
  { time: "18:30", date: "04 Mei", home: "Arsenal", away: "Bournemouth", league: "Premier League" },
  { time: "21:15", date: "04 Mei", home: "Real Madrid", away: "Cadiz", league: "La Liga" },
  { time: "01:45", date: "05 Mei", home: "Sassuolo", away: "Inter Milan", league: "Serie A" },
  { time: "22:30", date: "05 Mei", home: "Liverpool", away: "Spurs", league: "Premier League" }
];

const schemaData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "JalaLive",
  "alternateName": ["Jala Live", "JalaLive Streaming Bola", "JalaLive Alternatif"],
  "url": siteUrl,
  "description": pageDesc
};
---

<html lang="id">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" href="data:," />

    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

    <style>
        :root {
            --primary: #10b981;
            --secondary: #3b82f6;
            --dark: #0f172a;
            --surface: rgba(255, 255, 255, 0.03);
            --border: rgba(255, 255, 255, 0.08);
        }
        body {
            background-color: var(--dark);
            color: #f8fafc;
            font-family: 'Inter', system-ui, sans-serif;
            margin: 0;
            padding: 0;
            -webkit-user-select: none; user-select: none;
        }
        .bg-glow {
            position: fixed; top: -20%; left: 0; width: 100%; height: 100%;
            background: radial-gradient(circle at 50% 0%, rgba(16, 185, 129, 0.15) 0%, rgba(15, 23, 42, 1) 70%);
            z-index: -1;
        }
        .container { max-width: 1100px; margin: 0 auto; padding: 0 20px; }
        
        nav {
            display: flex; justify-content: space-between; align-items: center;
            padding: 25px 0; border-bottom: 1px solid var(--border);
        }
        .logo { font-size: 1.8rem; font-weight: 900; text-decoration: none; color: #fff; letter-spacing: -1px; }
        .logo span { color: var(--primary); }
        .partner-link { color: #64748b; text-decoration: none; font-size: 0.8rem; font-weight: 700; letter-spacing: 1px; }

        .hero { text-align: center; padding: 60px 0 50px; }
        .live-badge { 
            display: inline-block; background: #ef4444; color: #fff; font-size: 0.8rem; font-weight: 800; 
            padding: 6px 16px; border-radius: 50px; margin-bottom: 20px; letter-spacing: 1px;
            box-shadow: 0 0 15px rgba(239, 68, 68, 0.4); animation: pulse 2s infinite;
        }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.7; } }
        .hero h1 { font-size: 3rem; font-weight: 900; margin: 0 0 15px; line-height: 1.1; }
        .hero p { font-size: 1.1rem; color: #94a3b8; max-width: 700px; margin: 0 auto; line-height: 1.6; }

        .match-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px; margin-bottom: 60px; }
        .card {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 20px; padding: 25px; backdrop-filter: blur(10px);
            transition: all 0.3s ease;
        }
        .card:hover { border-color: var(--primary); transform: translateY(-5px); background: rgba(16, 185, 129, 0.05); }
        .league-tag {
            font-size: 0.7rem; font-weight: 800; color: var(--primary); text-transform: uppercase;
            border: 1px solid var(--primary); padding: 4px 10px; border-radius: 50px; display: inline-block; margin-bottom: 15px;
        }
        .teams { font-size: 1.25rem; font-weight: 800; margin-bottom: 20px; display: block; }
        .card-footer { display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--border); padding-top: 15px; }
        .time-info { font-size: 0.85rem; font-weight: 600; color: #94a3b8; }
        .btn-play {
            background: #fff; color: #000; text-decoration: none;
            padding: 8px 20px; border-radius: 12px; font-weight: 800; font-size: 0.75rem; transition: 0.3s;
        }
        .card:hover .btn-play { background: var(--primary); color: #fff; }

        .seo-box {
            background: rgba(0,0,0,0.4); border: 1px solid var(--border);
            border-radius: 24px; padding: 40px; margin-bottom: 60px; line-height: 1.8; color: #cbd5e1;
        }
        .seo-box h2 { color: #fff; font-size: 2rem; margin-top: 0; margin-bottom: 20px; }
        .seo-box h3 { color: #fff; font-size: 1.3rem; margin-top: 30px; margin-bottom: 15px; }
        .keyword-list { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 15px; }
        .keyword-list li { background: var(--surface); padding: 12px 20px; border-radius: 12px; border: 1px solid var(--border); font-weight: 600; font-size: 0.9rem; color: #38bdf8; display: flex; align-items: center; gap: 10px; }
        .keyword-list li::before { content: '✓'; color: var(--primary); font-weight: bold; }
        .seo-box p { margin-bottom: 15px; }
        .seo-box a { color: var(--primary); text-decoration: none; font-weight: bold; }
    </style>
</head>
<body>
    <div class="bg-glow"></div>

    <div class="container">
        <nav>
            <a href="/" class="logo">JALA<span>LIVE</span></a>
            <a href={partnerUrl} target="_blank" class="partner-link">SUPPORTED BY JALALIVE</a>
        </nav>

        <header class="hero">
            <span class="live-badge">🔴 LIVE STREAMING</span>
            <h1>JalaLive: Pusat Nonton Bola Hari Ini</h1>
            <p>Akses link JalaLive tercepat melalui domain instantradiostation.com. Nikmati siaran langsung pertandingan sepak bola dunia dengan resolusi HD tanpa hambatan.</p>
        </header>

        <main>
            <div class="match-grid">
                {matches.map((m) => (
                    <div class="card">
                        <span class="league-tag">{m.league}</span>
                        <span class="teams">{m.home} vs {m.away}</span>
                        <div class="card-footer">
                            <div class="time-info">{m.time} • {m.date}</div>
                            <a href={partnerUrl} target="_blank" class="btn-play">TONTON LIVE</a>
                        </div>
                    </div>
                ))}
            </div>

            <article class="seo-box">
                <h2>JalaLive Streaming: Link Alternatif Nonton Bola HD</h2>
                <p>
                    Selamat datang di <strong>JalaLive</strong>, portal utama bagi para penggemar sepak bola di Indonesia yang mencari link live streaming berkualitas. Melalui domain <em>instantradiostation.com</em>, kami menghadirkan jadwal pertandingan ter-update dan akses langsung ke server penyiaran olahraga paling stabil hasil kolaborasi dengan <a href={partnerUrl} target="_blank">JALALIVE</a>.
                </p>

                <h3>Fokus Layanan & Keywords Utama Kami:</h3>
                <ul class="keyword-list">
                    <li>JalaLive Streaming Bola</li>
                    <li>Nonton Bola Online Gratis</li>
                    <li>Live Streaming Liga Inggris</li>
                    <li>Link Alternatif JalaLive Terbaru</li>
                    <li>Jadwal Bola Hari Ini Live</li>
                    <li>JalaLive Apk Tanpa Buffering</li>
                    <li>Nonton Liga Champions HD</li>
                    <li>Streaming Bola Yandex Live</li>
                </ul>

                <h3>Kenapa Memilih Link JalaLive di Sini?</h3>
                <p>
                    Sebagai platform direktori <strong>JalaLive streaming</strong> terdepan, kami menggunakan teknologi server edge yang memastikan situs ini selalu dapat diakses meskipun terjadi lonjakan pengunjung saat laga <em>Big Match</em>. Sistem kami secara otomatis memperbarui tautan (link alternatif JalaLive) setiap hari sehingga Anda tidak perlu khawatir ketinggalan siaran tim kesayangan Anda. Mulai dari Premier League, Serie A, La Liga, hingga turnamen internasional, semuanya tersedia lengkap.
                </p>
            </article>
        </main>
        
        <footer style="text-align: center; padding: 40px 0; border-top: 1px solid var(--border); color: #64748b; font-size: 0.85rem;">
            &copy; 2026 JalaLive Network. Broadcasted via instantradiostation.com. Partnered with JALALIVE.
        </footer>
    </div>

    <script is:inline>
        document.addEventListener('contextmenu', e => e.preventDefault());
        document.onkeydown = function(e) {
            if (e.keyCode == 123 || 
               (e.ctrlKey && e.shiftKey && (e.keyCode == 'I'.charCodeAt(0) || e.keyCode == 'C'.charCodeAt(0) || e.keyCode == 'J'.charCodeAt(0))) || 
               (e.ctrlKey && (e.keyCode == 'U'.charCodeAt(0) || e.keyCode == 'S'.charCodeAt(0)))) {
                return false;
            }
        };
    </script>
</body>
</html>